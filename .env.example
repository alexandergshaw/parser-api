# Comma-separated list of allowed CORS origins (the other Vercel apps + the UI).
# Use "*" for local dev only; set explicit origins in production.
ALLOWED_ORIGINS=*

# Shared secret for app-to-app calls. When set, callers must send `X-API-Key`.
# Leave empty to run the API open (local dev / first deploy).
API_KEY=

# Confidence below this value (0..1) is flagged low-confidence in the response
# meta so the researcher API can degrade gracefully. Results are still returned.
CONFIDENCE_THRESHOLD=0.15
