{
  "openapi": "3.1.0",
  "info": {
    "title": "Parser API",
    "description": "Deterministic, LLM-free text extraction organized by composable lenses (emphasis axes, curated lexicons, and RAKE keywords).",
    "version": "1.0.0"
  },
  "paths": {
    "/api/parse": {
      "post": {
        "summary": "Parse text into lens-keyed results",
        "operationId": "parse",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParseRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Lens-keyed results",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParseResponse" } } }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" },
          "413": { "$ref": "#/components/responses/Error" },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/health": {
      "get": {
        "summary": "Liveness, version, taxonomy size",
        "operationId": "health",
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Health" } } } } }
      }
    },
    "/api/lenses": {
      "get": {
        "summary": "Enumerate available extraction lenses",
        "operationId": "lenses",
        "responses": { "200": { "description": "Lens registry", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Lenses" } } } } }
      }
    },
    "/api/taxonomy": {
      "get": {
        "summary": "Enumerate the emphasis vocabulary",
        "operationId": "taxonomy",
        "responses": { "200": { "description": "Vocabulary", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Taxonomy" } } } } }
      }
    }
  },
  "components": {
    "responses": {
      "Error": {
        "description": "Error",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    },
    "schemas": {
      "ParseRequest": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string", "description": "Text to analyze (1–50000 chars)." },
          "targets": {
            "description": "Lenses to compute. Omit for the default lenses. Each item is a lens name or {name, limit}. Restrictive: only the requested lenses are returned.",
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" }, "limit": { "type": "integer" } } }
              ]
            }
          },
          "max_keywords": { "type": "integer", "minimum": 1, "maximum": 50, "default": 15 }
        }
      },
      "ParseResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "object",
            "description": "Keyed by requested lens name; value depends on the lens kind.",
            "additionalProperties": {
              "oneOf": [
                { "$ref": "#/components/schemas/EmphasisLens" },
                { "$ref": "#/components/schemas/LexiconLens" },
                { "$ref": "#/components/schemas/KeywordsLens" }
              ]
            }
          },
          "meta": { "$ref": "#/components/schemas/Meta" }
        }
      },
      "Emphasis": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "score": { "type": "number", "description": "Share within the axis (0..1)." },
          "matched_terms": { "type": "array", "items": { "type": "string" } },
          "low_confidence": { "type": "boolean", "description": "Present on `top` only." }
        }
      },
      "EmphasisLens": {
        "type": "object",
        "properties": {
          "kind": { "type": "string", "enum": ["emphasis"] },
          "top": { "oneOf": [{ "$ref": "#/components/schemas/Emphasis" }, { "type": "null" }] },
          "ranked": { "type": "array", "items": { "$ref": "#/components/schemas/Emphasis" } }
        }
      },
      "Related": {
        "type": ["object", "null"],
        "properties": { "id": { "type": "string" }, "label": { "type": "string" } }
      },
      "LexiconLens": {
        "type": "object",
        "properties": {
          "kind": { "type": "string", "enum": ["lexicon"] },
          "matched": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "term": { "type": "string", "description": "Lowercased join key." },
                "display": { "type": "string" },
                "related": { "$ref": "#/components/schemas/Related" }
              }
            }
          }
        }
      },
      "KeywordsLens": {
        "type": "object",
        "properties": {
          "kind": { "type": "string", "enum": ["keywords"] },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "term": { "type": "string", "description": "Lowercased join key." },
                "display": { "type": "string" },
                "score": { "type": "number" },
                "source": { "type": "string", "enum": ["rake", "lexicon", "rake+lexicon"] },
                "related": { "$ref": "#/components/schemas/Related" }
              }
            }
          }
        }
      },
      "Meta": {
        "type": "object",
        "properties": {
          "token_count": { "type": "integer" },
          "version": { "type": "string" }
        }
      },
      "Health": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "version": { "type": "string" },
          "categories": { "type": "integer" }
        }
      },
      "Lenses": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "lenses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "kind": { "type": "string", "enum": ["emphasis", "lexicon", "keywords"] },
                "default": { "type": "boolean" }
              }
            }
          }
        }
      },
      "Taxonomy": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "count": { "type": "integer" },
          "categories": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": { "detail": { "type": "string" } }
      }
    }
  }
}
