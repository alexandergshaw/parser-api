# Comma-separated list of allowed CORS origins (the other Vercel apps + the UI).
# Use "*" for local dev only; set explicit origins in production.
ALLOWED_ORIGINS=*

# Shared secret for app-to-app calls. When set, callers must send `X-API-Key`.
# Leave empty to run the API open (local dev / first deploy).
API_KEY=

# Confidence below this value (0..1) is flagged low-confidence in the response
# meta so the researcher API can degrade gracefully. Results are still returned.
CONFIDENCE_THRESHOLD=0.15

# Ingestion limits (inline text + uploaded files are merged into one document).
# MAX_COMBINED_CHARS: cap on the merged text the parser sees (413 over cap).
# MAX_FILES: max number of uploaded files per request.
# MAX_FILE_BYTES: per-file size cap (oversized files fail softly, parse continues).
# MAX_TOTAL_UPLOAD_BYTES: whole-request body cap (413). NB: Vercel caps serverless
#   bodies at ~4.5 MB, below this default — large uploads may be rejected upstream.
MAX_COMBINED_CHARS=200000
MAX_FILES=20
MAX_FILE_BYTES=10485760
MAX_TOTAL_UPLOAD_BYTES=16777216
