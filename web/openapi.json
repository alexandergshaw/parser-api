{
  "openapi": "3.1.0",
  "info": {
    "title": "Parser API",
    "description": "Deterministic, LLM-free extraction of a text's broad emphases (curated taxonomy + lexicon scoring) and specific subtopics/keywords (RAKE).",
    "version": "0.3.3"
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Health Api Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/taxonomy": {
      "get": {
        "summary": "Taxonomy",
        "description": "Enumerate the controlled vocabulary so consumers can discover it dynamically.",
        "operationId": "taxonomy_api_taxonomy_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaxonomyResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/parse": {
      "post": {
        "summary": "Parse Text",
        "operationId": "parse_text_api_parse_post",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Api-Key"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ParseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParseResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CategoryInfo": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "type": {
            "type": "string",
            "title": "Type"
          }
        },
        "type": "object",
        "required": [
          "id",
          "label",
          "type"
        ],
        "title": "CategoryInfo"
      },
      "Emphasis": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "type": {
            "type": "string",
            "title": "Type"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "matched_terms": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Matched Terms"
          }
        },
        "type": "object",
        "required": [
          "id",
          "label",
          "type",
          "score",
          "matched_terms"
        ],
        "title": "Emphasis"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Keyword": {
        "properties": {
          "term": {
            "type": "string",
            "title": "Term"
          },
          "display": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Display"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "source": {
            "type": "string",
            "title": "Source"
          },
          "related_emphasis": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Related Emphasis"
          },
          "related_emphasis_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Related Emphasis Id"
          }
        },
        "type": "object",
        "required": [
          "term",
          "score",
          "source"
        ],
        "title": "Keyword"
      },
      "Meta": {
        "properties": {
          "token_count": {
            "type": "integer",
            "title": "Token Count"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "low_confidence": {
            "type": "boolean",
            "title": "Low Confidence"
          },
          "version": {
            "type": "string",
            "title": "Version"
          }
        },
        "type": "object",
        "required": [
          "token_count",
          "confidence",
          "low_confidence",
          "version"
        ],
        "title": "Meta"
      },
      "ParseRequest": {
        "properties": {
          "text": {
            "type": "string",
            "title": "Text",
            "description": "The block of text to analyze."
          },
          "max_keywords": {
            "type": "integer",
            "maximum": 50.0,
            "minimum": 1.0,
            "title": "Max Keywords",
            "description": "Max specific keywords to return.",
            "default": 15
          },
          "language": {
            "type": "string",
            "title": "Language",
            "description": "Reserved for future multi-language support.",
            "default": "en"
          }
        },
        "type": "object",
        "required": [
          "text"
        ],
        "title": "ParseRequest"
      },
      "ParseResponse": {
        "properties": {
          "primary": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Emphasis"
              },
              {
                "type": "null"
              }
            ]
          },
          "secondary": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Emphasis"
              },
              {
                "type": "null"
              }
            ]
          },
          "emphases": {
            "items": {
              "$ref": "#/components/schemas/Emphasis"
            },
            "type": "array",
            "title": "Emphases"
          },
          "keywords": {
            "items": {
              "$ref": "#/components/schemas/Keyword"
            },
            "type": "array",
            "title": "Keywords"
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        },
        "type": "object",
        "required": [
          "primary",
          "secondary",
          "emphases",
          "keywords",
          "meta"
        ],
        "title": "ParseResponse"
      },
      "TaxonomyResponse": {
        "properties": {
          "version": {
            "type": "string",
            "title": "Version"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          },
          "categories": {
            "items": {
              "$ref": "#/components/schemas/CategoryInfo"
            },
            "type": "array",
            "title": "Categories"
          }
        },
        "type": "object",
        "required": [
          "version",
          "count",
          "categories"
        ],
        "title": "TaxonomyResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}